# === PRODUCTION ENVIRONMENT VARIABLES ===
# Copy this file to .env.production and fill in your production values

# Base URLs
NEXT_PUBLIC_BASE_URL=https://permitai.eu
FRONTEND_URL=https://permitai.eu

# Database
DATABASE_URL=postgresql://[production_user]:[password]@[host]/[db]?sslmode=require

# Clerk Authentication (PRODUCTION - pk_live_...)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxx
CLERK_SECRET_KEY=sk_live_xxxxx
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe (PRODUCTION - pk_live_... et price_live_...)
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx

# Stripe Price IDs (créer ces produits dans Stripe Dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_xxxxx  # 29€/mois
STRIPE_PRICE_STARTER_YEARLY=price_xxxxx   # 228€/an (19€/mois)
STRIPE_PRICE_PRO_MONTHLY=price_xxxxx      # 89€/mois
STRIPE_PRICE_PRO_YEARLY=price_xxxxx       # 588€/an (49€/mois)
STRIPE_PRICE_CABINET_MONTHLY=price_xxxxx  # 199€/mois
STRIPE_PRICE_CABINET_YEARLY=price_xxxxx   # 1188€/an (99€/mois)

# AI APIs
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
GEMINI_API_KEY=AIzaSyA7dRJ0eiBwawWup11Z2Y-veR4CBq71MRU

# Email (Resend)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@permitai.eu

# Analytics (Plausible)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=permitai.eu

# ═══════════════════════════════════════════════════════════
# INSTRUCTIONS DE CONFIGURATION
# ═══════════════════════════════════════════════════════════

# 1. CLERK PRODUCTION
#    - Créer app production sur dashboard.clerk.dev
#    - Récupérer pk_live_ et sk_live_
#    - Configurer webhook: https://permitai.eu/api/webhooks/clerk
#    - Events: user.created, user.updated, user.deleted
#    - Activer Google OAuth

# 2. STRIPE PRODUCTION
#    - Passer en mode Live sur dashboard.stripe.com
#    - Créer 6 produits:
#      * Starter Mensuel: 29 EUR/month
#      * Starter Annuel: 228 EUR/year
#      * Pro Mensuel: 89 EUR/month
#      * Pro Annuel: 588 EUR/year
#      * Cabinet Mensuel: 199 EUR/month
#      * Cabinet Annuel: 1188 EUR/year
#    - Configurer webhook: https://permitai.eu/api/webhook/stripe
#    - Events: checkout.session.completed, customer.subscription.*, invoice.payment_failed

# 3. RESEND
#    - Créer compte sur resend.com
#    - Vérifier domaine permitai.eu
#    - Récupérer API key

# 4. PLAUSIBLE
#    - Créer compte sur plausible.io
#    - Ajouter site permitai.eu
#    - Copier script dans layout.js
